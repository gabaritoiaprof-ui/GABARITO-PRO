# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Optional. Custom API Key for Groq Cloud.
# Users can also configure this dynamically via Settings in the application UI.
GROQ_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_CLIENT_ID: Optional. Google Client ID for Google login authentication.
GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET: Optional. Google Client Secret for Google login authentication.
GOOGLE_CLIENT_SECRET=

# VITE_API_URL: Optional. URL of the hosted Express backend (e.g., when hosting the frontend on Vercel).
VITE_API_URL=
